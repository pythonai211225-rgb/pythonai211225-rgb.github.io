      options: [_d("QSkgIDIxIDMgNjA="),_d("QikgIDE3IDQgNjA="),_d("QykgIDIxIDMgNTc="),_d("RCkgIDIxIDQgNjA=")],
      _h: "cXg3IzA="
    },
    {
      question: _d("Zm9yIGkgaW4gcmFuZ2UoMyk6CiAgICBmb3IgaiBpbiByYW5nZSgyKToKICAgICAgICBwcmludCgnaGVsbG8nKQoKSG93IG1hbnkgbGluZXMgYXJlIHByaW50ZWQ/"),
      options: [_d("QSkgIDM="),_d("QikgIDI="),_d("QykgIDY="),_d("RCkgIDU=")],
      _h: "cXg3IzI="
    },
    {
      question: _d("d29yZHMgPSBbJ0hlbGxvJywgJ1dvcmxkJywgJ1B5dGhvbiddCnJlc3VsdCA9ICcgJy5qb2luKHdvcmRzKQpwcmludChyZXN1bHQpCgpXaGF0IGlzIHRoZSBvdXRwdXQ/"),
      options: [_d("QSkgIFsnSGVsbG8nLCAnV29ybGQnLCAnUHl0aG9uJ10="),_d("QikgIEhlbGxvV29ybGRQeXRob24="),_d("QykgIEhlbGxvIFdvcmxkIFB5dGhvbg=="),_d("RCkgIEhlbGxvLCBXb3JsZCwgUHl0aG9u")],
      _h: "cXg3IzI="
    },
    {
      question: _d("eCA9ICg0MiwpCnByaW50KHR5cGUoeCkp"),
      options: [_d("QSkgIDxjbGFzcyAnaW50Jz4="),_d("QikgIDxjbGFzcyAnbGlzdCc+"),_d("QykgIDxjbGFzcyAndHVwbGUnPg=="),_d("RCkgIDxjbGFzcyAnc2V0Jz4=")],
      _h: "cXg3IzI="
    }
  ];

  function _check(questionIndex, selectedIndex) {
    return btoa(_s + selectedIndex) === QUESTIONS[questionIndex]._h;
  }

  // ---- Quiz ID ----
  const quizId = 'Z' + String(Math.floor(10000 + Math.random() * 90000));
  document.getElementById('intro-quiz-id').textContent = 'Quiz ID: ' + quizId;

  // ---- state ----
  let student   = { fname: '', lname: '', id: '' };
  let current   = 0;
  let selected  = null;
  let order     = [];   // shuffled indices into QUESTIONS
  const answers = Array(QUESTIONS.length).fill(null);

  function shuffle(arr) {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  // ---- timer state ----
  let timerInterval = null;
  let startTs       = null;   // epoch ms when exam started
  let finalTime     = null;   // "MM:SS" saved at finish

  const STORE_KEY = 'pyexam_state';

  function saveState(done = false) {
    localStorage.setItem(STORE_KEY, JSON.stringify({ student, current, answers, done, startTs, finalTime, order }));
  }

  function clearState() {
    localStorage.removeItem(STORE_KEY);
  }

  function restoreState() {
    const raw = localStorage.getItem(STORE_KEY);
    if (!raw) return null;
    try {
      const s = JSON.parse(raw);
      if (!s.student || s.current == null || !Array.isArray(s.answers)) return null;
      student   = s.student;
      current   = s.current;
      startTs   = s.startTs   || null;
      finalTime = s.finalTime || null;
      order = Array.isArray(s.order) ? s.order : shuffle([...Array(QUESTIONS.length).keys()]);
      if (order.length !== QUESTIONS.length) { clearState(); return null; }
      s.answers.forEach((v, i) => { answers[i] = v; });
      return s.done ? 'done' : 'in-progress';
    } catch (e) { return null; }
  }

  // ---- timer helpers ----
  function fmtTime(ms) {
    const total = Math.floor(ms / 1000);
    const m = String(Math.floor(total / 60)).padStart(2, '0');
    const s = String(total % 60).padStart(2, '0');
    return `${m}:${s}`;
  }

  function startTimer() {
    if (timerInterval) clearInterval(timerInterval);
    timerInterval = setInterval(() => {
      document.getElementById('timer').textContent = fmtTime(Date.now() - startTs);
    }, 500);
  }

  function stopTimer() {
    clearInterval(timerInterval);
    timerInterval = null;
    finalTime = fmtTime(Date.now() - startTs);
  }

  // ---- intro ----
  function startExam() {
    const fn = document.getElementById('inp-fname').value.trim();
    const ln = document.getElementById('inp-lname').value.trim();
    const id = document.getElementById('inp-id').value.trim();

    if (!fn || !ln || !id) {
      document.getElementById('intro-warn').style.display = 'block';
      return;
    }

    student = { fname: fn, lname: ln, id };
    startTs = Date.now();
    order   = shuffle([...Array(QUESTIONS.length).keys()]);
    saveState();
    startTimer();
    document.getElementById('intro-screen').classList.add('hidden');
    document.getElementById('question-screen').classList.remove('hidden');
    render();
  }

  // ---- question ----
  function render() {
    const q     = QUESTIONS[order[current]];
    const total = QUESTIONS.length;

    document.getElementById('counter').textContent  = `Question ${current + 1} of ${total}`;
    document.getElementById('q-badge').textContent  = `Q${current + 1}`;
    document.getElementById('q-text').textContent = q.question;
    document.getElementById('prog-fill').style.width = `${((current + 1) / total) * 100}%`;
    document.getElementById('next-btn').textContent = current === total - 1 ? 'Finish ✓' : 'Next →';
    document.getElementById('q-warn').style.display = 'none';

    selected = answers[current];

    const container = document.getElementById('options');
    container.innerHTML = '';
    q.options.forEach((opt, i) => {
      const div = document.createElement('div');
      div.className = 'option' + (selected === i ? ' selected' : '');
      div.textContent = opt;
      div.addEventListener('click', () => selectOption(i));
      container.appendChild(div);
    });
  }

  function selectOption(idx) {
    selected = idx;
    answers[current] = idx;
    document.querySelectorAll('.option').forEach((el, i) =>
      el.classList.toggle('selected', i === idx)
    );
    document.getElementById('q-warn').style.display = 'none';
    saveState();
  }

  function nextQuestion() {
    if (selected === null) {
      document.getElementById('q-warn').style.display = 'block';
      return;
    }

    if (current < QUESTIONS.length - 1) {
      current++;
      saveState();
      render();
    } else {
      stopTimer();
      saveState(true);
      showResults();
    }
  }

  // ---- results ----
  function showResults() {
    const total = order.length;
    const score = order.reduce((acc, qIdx, i) => acc + (_check(qIdx, answers[i]) ? 1 : 0), 0);
    const pct   = Math.round(score / total * 100);
    const pass  = pct >= 60;

    document.getElementById('question-screen').classList.add('hidden');
    document.getElementById('results-screen').classList.remove('hidden');

    document.getElementById('student-info').innerHTML =
      `<strong>${student.fname} ${student.lname}</strong> &nbsp;·&nbsp; ID: <strong>${student.id}</strong>`;

    const accent = pass ? '#2F9E44' : '#E03131';
    document.getElementById('result-accent').style.background = accent;

    document.getElementById('res-emoji').textContent  = pct === 100 ? '🎉' : (pass ? '👍' : '📚');

    const ring = document.getElementById('pct-ring');
    ring.style.borderColor = accent;
    ring.style.color       = accent;
    document.getElementById('pct-value').textContent = pct + '%';

    document.getElementById('result-label').textContent = pass ? 'Passed' : 'Not Passed';
    document.getElementById('result-label').style.color = accent;
    document.getElementById('result-note').textContent  =
      pass ? 'Well done! You passed the exam.' : '';
    document.getElementById('result-time').textContent  =
      finalTime ? `⏱ Time: ${finalTime}` : '';
    document.getElementById('result-quiz-id').textContent = 'Quiz ID: ' + quizId;
  }

  // ---- restart ----
  function restart() {
    if (!confirm('Are you sure you want to start over? Your answers will be lost.')) return;
    current   = 0;
    startTs   = null;
    finalTime = null;
    order     = [];
    answers.fill(null);
    selected = null;
    if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
    clearState();

    document.getElementById('inp-fname').value = '';
    document.getElementById('inp-lname').value = '';
    document.getElementById('inp-id').value    = '';
    document.getElementById('intro-warn').style.display = 'none';

    document.getElementById('results-screen').classList.add('hidden');
    document.getElementById('intro-screen').classList.remove('hidden');
  }

  // ---- on page load: resume if state exists ----
  (function init() {
    const state = restoreState();
    if (state === 'done') {
      document.getElementById('intro-screen').classList.add('hidden');
      showResults();
    } else if (state === 'in-progress') {
      document.getElementById('intro-screen').classList.add('hidden');
      document.getElementById('question-screen').classList.remove('hidden');
      render();
      if (startTs) startTimer();
    }
  })();

  // block copy/cut on the question area
  document.addEventListener('copy', e => {
    if (document.getElementById('question-screen') &&
        !document.getElementById('question-screen').classList.contains('hidden')) {
      e.preventDefault();
    }
  });

  // allow Enter key on intro fields
  ['inp-fname','inp-lname','inp-id'].forEach(id =>
    document.getElementById(id).addEventListener('keydown', e => {
      if (e.key === 'Enter') startExam();
    })
  );
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Python Basics Exam</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #F0F4FF;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .exam-wrapper { width: 100%; max-width: 660px; }

    /* ---- shared header ---- */
    .header {
      background: #3B5BDB;
      border-radius: 16px 16px 0 0;
      padding: 18px 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .header h1  { color: #fff; font-size: 1.25rem; }
    .header span { color: #C5D0FF; font-size: 0.95rem; }

    /* ---- progress bar ---- */
    .prog-track { background: #D0D7FF; height: 6px; }
    .prog-fill  {
      height: 6px; background: #4C6EF5; width: 0%;
      transition: width 0.4s ease;
    }

    /* ---- card ---- */
    .card {
      background: #fff;
      border: 1px solid #D0D7FF;
      border-top: none;
      border-radius: 0 0 16px 16px;
      padding: 32px 36px 28px;
    }

    /* ---- intro screen ---- */
    .intro-subtitle {
      color: #6C757D;
      font-size: 0.95rem;
      margin-bottom: 28px;
      line-height: 1.5;
    }

    .field-group { display: flex; flex-direction: column; gap: 16px; margin-bottom: 28px; }

    .field label {
      display: block;
      font-size: 0.82rem;
      font-weight: 700;
      color: #3B5BDB;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 6px;
    }

    .field input {
      width: 100%;
      padding: 11px 14px;
      border: 1.5px solid #D0D7FF;
      border-radius: 10px;
      font-size: 1rem;
      font-family: 'Segoe UI', sans-serif;
      color: #1A1A2E;
      background: #F8F9FF;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .field input:focus {
      border-color: #4C6EF5;
      box-shadow: 0 0 0 3px #C5D0FF55;
      background: #fff;
    }

    /* ---- question screen ---- */
    .q-badge {
      display: inline-block;
      background: #4C6EF5;
      color: #fff;
      font-size: 0.78rem;
      font-weight: 700;
      padding: 3px 12px;
      border-radius: 20px;
      margin-bottom: 14px;
    }

    .q-text {
      color: #1A1A2E;
      font-size: 1.1rem;
      font-weight: 700;
      line-height: 1.6;
      margin-bottom: 22px;
      white-space: pre-wrap;
      user-select: none;
      -webkit-user-select: none;
    }

    .options { display: flex; flex-direction: column; gap: 10px; }

    .option {
      border: 1.5px solid #D0D7FF;
      border-radius: 10px;
      padding: 12px 18px;
      cursor: pointer;
      color: #1A1A2E;
      font-size: 1rem;
      transition: background 0.15s, border-color 0.15s;
      user-select: none;
    }
    .option:hover    { background: #E8EDFF; border-color: #4C6EF5; }
    .option.selected { background: #C5D0FF; border-color: #4C6EF5; }

    /* ---- footer row ---- */
    .footer {
      margin-top: 22px;
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 14px;
    }

    .warn {
      font-size: 0.85rem;
      color: #E03131;
      margin-right: auto;
      display: none;
    }

    .btn {
      background: #4C6EF5;
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 11px 28px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.15s;
    }
    .btn:hover { background: #3B5BDB; }
    .btn:disabled { background: #A5B4FC; cursor: not-allowed; }

    /* ---- results ---- */
    .result-accent { height: 5px; }

    .results-card {
      background: #fff;
      border: 1px solid #D0D7FF;
      border-top: none;
      border-radius: 0 0 16px 16px;
      padding: 40px 36px 36px;
      text-align: center;
    }

    .student-info {
      font-size: 0.95rem;
      color: #6C757D;
      margin-bottom: 28px;
    }
    .student-info strong { color: #1A1A2E; }

    .big-emoji { font-size: 3.5rem; margin-bottom: 10px; }

    .pct-ring {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 130px;
      height: 130px;
      border-radius: 50%;
      border: 8px solid;
      margin-bottom: 14px;
    }
    .pct-value {
      font-size: 2.2rem;
      font-weight: 800;
    }

    .result-label {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .result-note { color: #6C757D; font-size: 0.9rem; }

    /* ---- timer ---- */
    .timer {
      font-size: 0.95rem;
      font-weight: 700;
      color: #40C057;
      letter-spacing: 0.04em;
      font-variant-numeric: tabular-nums;
    }

    .result-time {
      font-size: 0.9rem;
      color: #40C057;
      font-weight: 600;
      margin-top: 8px;
    }

    .quiz-id-badge {
      display: inline-block;
      background: #EEF2FF;
      color: #3B5BDB;
      border: 1.5px solid #C5D0FF;
      border-radius: 8px;
      font-size: 0.88rem;
      font-weight: 700;
      padding: 6px 16px;
      margin-bottom: 22px;
      letter-spacing: 0.05em;
    }

    .result-quiz-id {
      font-size: 0.88rem;
      color: #6C757D;
      margin-top: 10px;
      letter-spacing: 0.04em;
    }

    /* hide sections */
    .hidden { display: none; }
  </style>
</head>
<body>

<div class="exam-wrapper">

  <!-- ========= INTRO SCREEN ========= -->
  <div id="intro-screen">
    <div class="header">
      <h1>🐍 Python Basics Exam</h1>
      <span>50 Questions</span>
    </div>
    <div style="height:6px;background:#D0D7FF;"></div>
    <div class="card">
      <div class="quiz-id-badge" id="intro-quiz-id"></div>
      <p class="intro-subtitle">
        Please enter your details below before starting the exam.<br/>
        You will have one question per page. Your score will be shown at the end.
      </p>
      <div class="field-group">
        <div class="field">
          <label>First Name</label>
          <input type="text" id="inp-fname" placeholder="e.g. John" autocomplete="off"/>
        </div>
        <div class="field">
          <label>Last Name</label>
          <input type="text" id="inp-lname" placeholder="e.g. Smith" autocomplete="off"/>
        </div>
        <div class="field">
          <label>Student ID</label>
          <input type="text" id="inp-id" placeholder="e.g. 20240001" autocomplete="off"/>
        </div>
      </div>
      <div class="footer">
        <span class="warn" id="intro-warn">⚠ Please fill in all fields.</span>
        <button class="btn" onclick="startExam()">Start Exam →</button>
      </div>
    </div>
  </div>

  <!-- ========= QUESTION SCREEN ========= -->
  <div id="question-screen" class="hidden">
    <div class="header">
      <h1>🐍 Python Basics Exam</h1>
      <span class="timer" id="timer">00:00</span>
      <span id="counter">Question 1 of 5</span>
    </div>
    <div class="prog-track">
      <div class="prog-fill" id="prog-fill"></div>
    </div>
    <div class="card">
      <div class="q-badge" id="q-badge">Q1</div>
      <div class="q-text"  id="q-text"></div>
      <div class="options" id="options"></div>
      <div class="footer">
        <span class="warn" id="q-warn">⚠ Please select an answer first.</span>
        <button class="btn" id="next-btn" onclick="nextQuestion()">Next →</button>
      </div>
    </div>
  </div>

  <!-- ========= RESULTS SCREEN ========= -->
  <div id="results-screen" class="hidden">
    <div class="header">
      <h1>🐍 Python Basics Exam</h1>
      <span>Results</span>
    </div>
    <div class="result-accent" id="result-accent"></div>
    <div class="results-card">
      <div class="student-info" id="student-info"></div>
      <div class="big-emoji"   id="res-emoji"></div>
      <div class="pct-ring"    id="pct-ring">
        <span class="pct-value" id="pct-value"></span>
      </div>
      <div class="result-label" id="result-label"></div>
      <div class="result-note"  id="result-note"></div>
      <div class="result-time"  id="result-time"></div>
      <div class="result-quiz-id" id="result-quiz-id"></div>
    </div>
    <div class="footer" style="padding: 0 0 4px;">
      <button class="btn" onclick="restart()">↺ Try Again</button>
    </div>
  </div>

</div>

<script>

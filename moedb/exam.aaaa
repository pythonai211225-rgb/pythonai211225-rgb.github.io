    {
      question: _d("bmFtZSA9ICdhTGlDZScKcHJpbnQoZiJVcHBlcjoge25hbWUudXBwZXIoKX0gfCBMb3dlcjoge25hbWUubG93ZXIoKX0iKQ=="),
      options: [_d("QSkgIFVwcGVyOiBhTGlDZSB8IExvd2VyOiBhTGlDZQ=="),_d("QikgIFVwcGVyOiBBbGljZSB8IExvd2VyOiBhbGljZQ=="),_d("QykgIFVwcGVyOiBBTElDRSB8IExvd2VyOiBhbGljZQ=="),_d("RCkgIFVwcGVyOiBBTElDRSB8IExvd2VyOiBBTElDRQ==")],
      _h: "cXg3IzI="
    },
    {
      question: _d("cHJpY2UgPSA0OS41Njc4CnByaW50KGYnVG90YWw6IHtwcmljZTouMmZ9JykKCldoYXQgaXMgdGhlIG91dHB1dD8="),
      options: [_d("QSkgIFRvdGFsOiA0OS41Njc4"),_d("QikgIFRvdGFsOiA0OQ=="),_d("QykgIFRvdGFsOiB7cHJpY2U6LjJmfQ=="),_d("RCkgIFRvdGFsOiA0OS41Nw==")],
      _h: "cXg3IzM="
    },
    {
      question: _d("bnVtcyA9IFs1LCAyLCA4LCAyLCAxLCA1LCA5XQpudW1zLnNvcnQoKQpwcmludChudW1zKQoKV2hhdCBpcyB0aGUgb3V0cHV0Pw=="),
      options: [_d("QSkgIFsxLCAyLCA1LCA4LCA5XQ=="),_d("QikgIFsxLCAyLCAyLCA1LCA1LCA4LCA5XQ=="),_d("QykgIFs5LCA4LCA1LCA1LCAyLCAyLCAxXQ=="),_d("RCkgIFs1LCAyLCA4LCAyLCAxLCA1LCA5XQ==")],
